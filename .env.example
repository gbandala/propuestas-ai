# Copia este archivo a .env.local y rellena los valores reales.
# .env.local nunca se commitea al repositorio.

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Modelos AI (opcionales, se usan los defaults si no se definen)
IMAGE_MODEL_FLASH=google/gemini-2.0-flash-exp:free
IMAGE_MODEL_PRO=google/gemini-2.0-flash-exp:free
IMAGE_MODEL_FLUX=black-forest-labs/flux-1.1-pro
TEXT_MODEL=anthropic/claude-sonnet-4-6

# URL pública del sitio
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# Secreto para rutas internas — genera con: openssl rand -base64 32
INTERNAL_API_SECRET=cambia-esto-por-un-valor-aleatorio-seguro

# Dev only
DEV_SEED_EMAIL=test@propuestasai.dev
DEV_SEED_PASSWORD=cambia-esto-tambien
